# .env.example — Copy to .env and fill in your API keys

# ── LLM ──────────────────────────────────────────────────────────────────────
# HuggingFace (default — free tier)
MODEL=openai/moonshotai/Kimi-K2-Instruct-0905
HF_TOKEN=your_hf_token_here
# Get your token at: https://huggingface.co/settings/tokens

# Alternative: use OpenAI or Anthropic for more reliable structured outputs
# MODEL=gpt-4o-mini
# OPENAI_API_KEY=your_openai_key_here
# MODEL=claude-sonnet-4-5
# ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Memory (Zep) ─────────────────────────────────────────────────────────────
ZEP_API_KEY=
# Get your key at: https://app.getzep.com

# ── Web Search (Firecrawl) ───────────────────────────────────────────────────
FIRECRAWL_API_KEY=
# Get your key at: https://firecrawl.dev

# ── Document Parsing (Tensorlake) ────────────────────────────────────────────
TENSORLAKE_API_KEY=
# Get your key at: https://tensorlake.ai

# ── Vector DB (ChromaDB — cross-platform) ────────────────────────────────────
# No key required — ChromaDB stores data locally in a directory
CHROMA_DB_PATH=./chroma_db
